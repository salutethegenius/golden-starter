# --- Web (Next.js) ---
# Required for Supabase auth. Get from Supabase project: Connect > Next.js
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (for admin operations - KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for email links and Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API URL (browser calls this)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (Email) ---
RESEND_API_KEY=re_...
EMAIL_FROM=A.M.T Imports <onboarding@resend.dev>
ADMIN_EMAIL=admin@amtimports.com

# --- API (FastAPI) ---
# Allowed frontend origins for CORS (comma-separated). Defaults to localhost:3000 and :3001
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: for AI features (LLM, embeddings, Qdrant)
# OPENAI_API_KEY=sk-...
# LLM_API_KEY=...
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...
